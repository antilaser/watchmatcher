# ---- Application ----
APP_NAME=watchmatch
APP_ENV=local
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_TIMEZONE=UTC

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=*

# ---- Docker host port mappings (override if defaults clash) ----
API_HOST_PORT=8000
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379

# ---- Security ----
JWT_SECRET=change-me-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
WEBHOOK_HMAC_SECRET=change-me-too

# ---- Database (PostgreSQL + pgvector) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=watchmatch
POSTGRES_PASSWORD=watchmatch
POSTGRES_DB=watchmatch
DATABASE_URL=postgresql+asyncpg://watchmatch:watchmatch@postgres:5432/watchmatch
DATABASE_URL_SYNC=postgresql+psycopg://watchmatch:watchmatch@postgres:5432/watchmatch

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---- LLM (OpenAI) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
LLM_ENABLED=true

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_ENABLED=false

# ---- Workspace defaults ----
DEFAULT_WORKSPACE_NAME=default
DEFAULT_MIN_MATCH_CONFIDENCE=0.75
DEFAULT_MIN_PROFIT_THRESHOLD=300.0
DEFAULT_SHIPPING_COST=80.0
DEFAULT_FEE_PERCENT=0.01
DEFAULT_FIXED_FEE=0.0
DEFAULT_RISK_BUFFER=100.0

# ---- Parsing ----
RULE_PARSE_CONFIDENCE_THRESHOLD=0.7
LLM_FALLBACK_ENABLED=true
ALERT_DEDUPE_HOURS=24
EXPIRE_OFFER_DAYS=30
EXPIRE_REQUEST_DAYS=60
